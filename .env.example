TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_ALLOWED_USERNAMES=telegram_username
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_PRIVATE_ONLY=true

CODEX_TELEGRAM_WORKDIR=/opt/customer-project
CODEX_TELEGRAM_CLI_PATH=/usr/bin/codex
CODEX_TELEGRAM_DANGEROUS_BYPASS=true
CODEX_TELEGRAM_SKIP_GIT_REPO_CHECK=true
CODEX_TELEGRAM_PROFILE=
CODEX_TELEGRAM_MODEL=
CODEX_TELEGRAM_POLL_TIMEOUT_SECONDS=50
CODEX_TELEGRAM_MAX_MESSAGE_CHARS=3500
CODEX_TELEGRAM_MAX_ATTACHMENT_BYTES=52428800
CODEX_TELEGRAM_HEARTBEAT_INTERVAL_SECONDS=30
CODEX_TELEGRAM_STATE_FILE=/opt/codex-telegram/.codex-telegram-bot/state.json
CODEX_TELEGRAM_SESSION_INDEX_FILE=/root/.codex/session_index.jsonl
CODEX_TELEGRAM_UPLOADS_DIR=/opt/codex-telegram/.codex-telegram-bot/uploads
CODEX_TELEGRAM_LOG_LEVEL=INFO

# Optional: if this host reaches the internet only via proxy, define these too.
# HTTP_PROXY=http://user:pass@proxy-host:8888
# HTTPS_PROXY=http://user:pass@proxy-host:8888
# ALL_PROXY=http://user:pass@proxy-host:8888
# NO_PROXY=localhost,127.0.0.1
